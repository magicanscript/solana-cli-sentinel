# ============================================================
# solana-cli-sentinel — пример конфигурации
# Скопируйте этот файл в .env и заполните своими значениями:
#   cp .env.example .env
# ============================================================

# --- Solana RPC ---

# URL ноды, за которой ведётся наблюдение. ОБЯЗАТЕЛЬНО.
# Примеры:
#   http://192.168.1.10:8899      (локальная нода)
#   http://validator.example.com:8899
SOLANA_TARGET_RPC_URL=http://your-node:8899

# URL эталонной ноды для сравнения слотов.
# По умолчанию — официальная mainnet-beta. Обычно менять не нужно.
SOLANA_REFERENCE_RPC_URL=https://api.mainnet-beta.solana.com

# --- Параметры polling ---

# Интервал между опросами нод (в секундах). По умолчанию: 10
SENTINEL_POLL_INTERVAL_SECS=10

# --- Пороги алертов ---

# Максимально допустимое отставание target-ноды от reference (в слотах).
# Если (reference_slot - target_slot) > ПОРОГА → алерт. По умолчанию: 5
SENTINEL_SLOT_LAG_THRESHOLD=5

# Максимально допустимый RTT target-ноды (в миллисекундах).
# Если RTT превышает порог → алерт. По умолчанию: 500
SENTINEL_RTT_THRESHOLD_MS=500

# Минимальный интервал между двумя алертами (в секундах).
# Предотвращает спам в Telegram при затяжной проблеме. По умолчанию: 300 (5 мин)
SENTINEL_ALERT_COOLDOWN_SECS=300

# --- Mistral LLM ---

# Секретный ключ Mistral API. ОБЯЗАТЕЛЬНО.
# Получить: https://console.mistral.ai/api-keys/
MISTRAL_API_KEY=your-mistral-api-key-here

# Модель для генерации алертов. По умолчанию: mistral-small-latest
MISTRAL_MODEL=mistral-small-latest

# --- Telegram ---

# Токен Telegram-бота. ОБЯЗАТЕЛЬНО.
# Создать бота и получить токен: https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=123456789:ABCDEFabcdef-your-bot-token-here

# ID чата или канала для отправки алертов. ОБЯЗАТЕЛЬНО.
# Личный чат: узнать через @userinfobot или https://t.me/getidsbot
# Канал/группа: отрицательное число вида -1001234567890
TELEGRAM_CHAT_ID=123456789
